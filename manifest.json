{
  "manifest_version": 3,
  "name": "Gemini Side Panel",
  "version": "1.3",
  "description": "Opens Gemini in the side panel with advanced features like persistence and context menu.",
  "permissions": [
    "sidePanel",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "storage",
    "contextMenus",
    "clipboardWrite",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Gemini Side Panel"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
