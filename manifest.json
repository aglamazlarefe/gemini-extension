{
  "manifest_version": 3,
  "name": "Gemini Side Panel",
  "version": "3.9",
  "description": "Opens Gemini in the side panel with 'Write-Only' security, session persistence, and smart productivity tools.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "sidePanel",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "storage",
    "contextMenus",
    "clipboardWrite",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Gemini Side Panel",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Toggle Gemini Side Panel"
    },
    "explain-selection": {
      "suggested_key": {
        "default": "Alt+Q"
      },
      "description": "Explain selection with Gemini"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content_script.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ]
}